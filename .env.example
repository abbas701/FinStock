# -----------------------------
# Server runtime
# -----------------------------
NODE_ENV=development
# Railway provides PORT automatically in deployed environments.
PORT=3000

# Public base URL of this app (required in production for reset links)
# Example (production): https://your-app-domain.com
# On Railway, this can be omitted if RAILWAY_PUBLIC_DOMAIN is present.
APP_BASE_URL=http://localhost:3000

# Session secret for signing cookies/JWT.
# In production, COOKIE_SECRET (or JWT_SECRET) must be set and non-default.
COOKIE_SECRET=replace_with_a_long_random_secret

# -----------------------------
# Database (Supabase Postgres)
# -----------------------------
# Use the Supabase connection pooler URL for serverless/edge platforms.
# Example format:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require

# -----------------------------
# Market data provider
# -----------------------------
# Supported values: yahoo_finance2 | alpha_vantage
MARKET_API_PROVIDER=yahoo_finance2
# Required only if MARKET_API_PROVIDER=alpha_vantage
MARKET_API_KEY=

# -----------------------------
# Optional OAuth integration
# -----------------------------
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=stock-portfolio-tracker

# Optional app branding
VITE_APP_TITLE=Stock Portfolio Tracker

# Optional: backend API base URL for frontend-only deployments (e.g., Vercel frontend + separate backend)
# Keep empty for single-service deploys (frontend and backend together).
# Example: https://api.yourdomain.com
VITE_API_BASE_URL=
