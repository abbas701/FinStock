# -----------------------------
# Required production variables
# -----------------------------
NODE_ENV=production
# Railway provides PORT automatically at runtime.
# Keep this for local parity only.
PORT=3000

# Public app URL used for absolute links (for example password reset links).
# On Railway, you can set this manually, or rely on RAILWAY_PUBLIC_DOMAIN auto-detection.
APP_BASE_URL=https://your-app.up.railway.app

COOKIE_SECRET=replace_with_a_long_random_secret

# Supabase pooler connection string (recommended for hosted runtimes)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require

# -----------------------------
# Optional variables
# -----------------------------
MARKET_API_PROVIDER=yahoo_finance2
MARKET_API_KEY=

# Optional OAuth
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=stock-portfolio-tracker
VITE_APP_TITLE=Stock Portfolio Tracker

# Leave empty when frontend and backend are deployed together in one Railway service.
# Set only when frontend is deployed separately from backend.
VITE_API_BASE_URL=
